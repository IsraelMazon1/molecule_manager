# PostgreSQL
POSTGRES_USER=molecule_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=molecule_db

# Used by FastAPI locally (Docker Compose overrides host to "db")
DATABASE_URL=postgresql://molecule_user:changeme@localhost:5432/molecule_db

# Session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-key

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Set to True when running behind HTTPS in production
COOKIE_SECURE=False

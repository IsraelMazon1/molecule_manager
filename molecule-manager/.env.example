# ── Local Docker Compose (not needed on Railway/Vercel) ──────────
POSTGRES_USER=molecule_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=molecule_db

# ── Backend (Railway) ────────────────────────────────────────────
# Connection string — Railway provides this automatically via its PostgreSQL plugin
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Session signing key (min 32 chars) — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-random-secret-key

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Cookie Secure flag — true for production (HTTPS), false for local dev (HTTP)
COOKIE_SECURE=true

# Cookie SameSite attribute — Lax (default) or Strict
COOKIE_SAMESITE=Lax

# Environment name — "production" or "development"
ENV=production

# Public-facing app URL — used in email links (no trailing slash)
APP_URL=https://your-frontend.vercel.app

# Resend API key for email notifications (optional — emails are skipped if not set)
RESEND_API_KEY=

# ── Frontend (Vercel) ────────────────────────────────────────────
# Must include the scheme and no trailing slash
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
